# OpenAI
OPENAI_API_KEY=""
GROQ_API_KEY=""

# Model configuration
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.7
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TEMPERATURE=0.3

# Per-agent model overrides (optional)
LLM_POST_WRITER_PROVIDER=openai
LLM_POST_WRITER_MODEL=gpt-4o-mini
LLM_POST_WRITER_TEMPERATURE=0.7

LLM_CODE_EXAMPLE_PROVIDER=openai
LLM_CODE_EXAMPLE_MODEL=gpt-4o-mini
LLM_CODE_EXAMPLE_TEMPERATURE=0.2

LLM_REVIEWER_PROVIDER=groq
LLM_REVIEWER_MODEL=llama-3.1-8b-instant
LLM_REVIEWER_TEMPERATURE=0.1

LLM_METADATA_PROVIDER=openai
LLM_METADATA_MODEL=gpt-4o-mini
LLM_METADATA_TEMPERATURE=0.0

LLM_TRANSLATOR_PROVIDER=openai
LLM_TRANSLATOR_MODEL=gpt-4o-mini
LLM_TRANSLATOR_TEMPERATURE=0.2

# App config
APP_ENV=development
APP_PORT=3015
